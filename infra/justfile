# justfile - OCI OpenTofu infrastructure management
# Run from root:  just -f infra/justfile <recipe>
# Run from infra/: just <recipe>

# Default recipe
default:
    @just --list

# ── Secrets ────────────────────────────────────────────────────────────────────

# Edit (or create) secrets/oci.yaml with sops
# Required keys: oci-tenancy-id (or oci-tenancy-ocid), oci-user-ocid,
#                oci-fingerprint, oci-region, oci-compartment-ocid,
#                oci-private-key, oci-public-key, r2-access-key-id,
#                r2-secret-access-key, r2-account-id, r2-bucket-name
edit-secrets:
    nix shell nixpkgs#sops nixpkgs#age -c sops ../secrets/oci.yaml

# ── OCI image ─────────────────────────────────────────────────────────────────

# Build the NixOS OCI qcow2 image expected by var.image_path.
# Produces ./result/nixos.qcow2 as a symlink to the Nix store output.
# Requires an aarch64-linux builder; Darwin without one cannot build this.
build-image:
    #!/usr/bin/env bash
    set -euo pipefail

    out_link="result-vps-image"
    image_dir="result"
    image_name="$(nix eval ..#nixosConfigurations.dathomir.config.image.fileName --raw)"

    nix build ..#packages.aarch64-linux.vps-image \
        --system aarch64-linux \
        --accept-flake-config \
        --out-link "$out_link"

    if [ ! -e "$out_link/$image_name" ]; then
        echo "ERROR: expected image not found: $out_link/$image_name" >&2
        exit 1
    fi

    rm -rf "$image_dir"
    mkdir -p "$image_dir"
    ln -s "../$out_link/$image_name" "$image_dir/nixos.qcow2"

    echo "OCI image ready: $image_dir/nixos.qcow2 -> ../$out_link/$image_name"

# ── OpenTofu commands ─────────────────────────────────────────────────────────

# Initialize OpenTofu with S3-compatible R2 backend
# Uses secrets/oci.yaml via sops exec-env and infra/tofu-env.sh.
init *ARGS:
    nix shell nixpkgs#sops nixpkgs#opentofu -c sops exec-env ../secrets/oci.yaml './tofu-env.sh init {{ARGS}}'

# Run any tofu command with env from sops secrets
# Usage: just tf plan [-out=tfplan]
#        just tf apply [-auto-approve]
#        just tf destroy
# The OCI private key is written to a temp file and cleaned up on exit.
tf CMD *ARGS:
    nix shell nixpkgs#sops nixpkgs#opentofu -c sops exec-env ../secrets/oci.yaml './tofu-env.sh tofu {{CMD}} {{ARGS}}'

# Alias for explicit OpenTofu naming: just tofu plan
tofu CMD *ARGS:
    nix shell nixpkgs#sops nixpkgs#opentofu -c sops exec-env ../secrets/oci.yaml './tofu-env.sh tofu {{CMD}} {{ARGS}}'
