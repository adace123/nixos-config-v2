# Auth/backend vars come from secrets/oci.yaml via sops exec-env locally,
# and from GitHub Secrets in CI. infra/tofu-env.sh maps them for OpenTofu.
# Run:  just build-image  # produce ./result/nixos.qcow2
#       just init         # one-time backend setup
#       just tf plan      # plan with OpenTofu
#       just tf apply     # apply with OpenTofu
#
# Only non-secret instance config goes here. ssh_public_key is sourced from
# secrets/oci.yaml key `oci-public-key` by infra/tofu-env.sh.

image_path = "./result/nixos.qcow2"
